		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Natural",
					"slug": "natural",
					"shadow": "0 0 1rem rgba(0, 0, 0, 0.2)"
				}
			]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			],
			"blockGap": true
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Quicksand",
							"fontStyle": "normal",
							"fontWeight": "300 700",
							"src": [
								"file:./assets/fonts/Quicksand-VariableFont_wght.ttf"
							]
						}
					],
					"fontFamily": "'Quicksand', sans-serif",
					"name": "Headings",
					"slug": "headings"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Open Sans",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "400 700",
							"src": [
								"file:./assets/fonts/OpenSans-VariableFont.ttf"
							]
						},
						{
							"fontFamily": "Open Sans",
							"fontStretch": "normal",
							"fontStyle": "italic",
							"fontWeight": "400 700",
							"src": [
								"file:./assets/fonts/OpenSans-Italic-VariableFont.ttf"
							]
						}
					],
					"fontFamily": "'Open Sans', sans-serif",
					"name": "Body",
					"slug": "body"
				}
			]
		}
	},
	"styles": {
		"spacing": {
			"margin": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			},
			"padding": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			},
			"blockGap": "1rem"
		},
		"blocks": {
			"core/post-content": {
				"spacing": {
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					},
					"blockGap": 0
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					},
					"blockGap": 0
				}
			},
			"core/columns": {
				"spacing": {
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					},
					"blockGap": 0
				}
			},
			"core/column": {
				"spacing": {
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					}
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "var(--wp--preset--color--secondary)",
							"style": "solid",
							"width": "3px"
						},
						"color": {
							"background": "transparent",
							"text": "var(--wp--preset--color--secondary)"
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontWeight": "500",
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"core/group": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--50)",
						"right": "var(--wp--preset--spacing--50)",
						"bottom": "var(--wp--preset--spacing--50)",
						"left": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/image": {
				"shadow": "var(--wp--preset--shadow--natural)",
				"border": {
					"radius": "1rem"
				},
				"spacing": {
					"margin": {
						"top": "0",
						"right": "0",
						"bottom": "0",
						"left": "0"
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--secondary)",
					"text": "var(--wp--preset--color--base)"
				},
				"border": {
					"radius": "0.5rem"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)",
					"fontWeight": "600"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent-1)"
				}
			},
			"h1": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontSize": "2.8rem",
					"fontWeight": "700"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "2.2rem",
					"fontWeight": "700"
				}
			},
			"h3": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontSize": "2rem",
					"fontWeight": "700"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "1.6rem",
					"fontWeight": "600"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "1.4rem",
					"fontWeight": "600"
				}
			},
			"h6": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontSize": "1.2rem",
					"fontWeight": "500"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--headings)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "16px"
		}
	},
